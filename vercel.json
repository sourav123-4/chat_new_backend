{
  "version": 2,
  "buildCommand": "npm run build && rm -rf dist/src/server.js dist/src/server.d.ts",
  "routes": [
    {
      "src": "^/(.*)$",
      "dest": "api/index.ts"
    }
  ],
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
 "rewrites": [
    { "source": "/api-docs", "destination": "/api/index.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" }
  ]
}